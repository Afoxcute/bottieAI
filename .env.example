# ─── Privy ───────────────────────────────────────────────────────────────────
# Get from https://console.privy.io → your app → Settings
NEXT_PUBLIC_PRIVY_APP_ID=

# Server-side only — NEVER prefix with NEXT_PUBLIC_
PRIVY_APP_SECRET=

# ─── RPC ─────────────────────────────────────────────────────────────────────
# Get from https://dashboard.alchemy.com → create app on Base Sepolia
NEXT_PUBLIC_ALCHEMY_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# Get from https://neon.tech → create project → connection string
DATABASE_URL=

# ─── AI ──────────────────────────────────────────────────────────────────────
# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenAI (voice transcription via Whisper) — https://platform.openai.com
OPENAI_API_KEY=

# ─── Circle Gateway Nanopayments (Base Sepolia) ───────────────────────────────
#
# CIRCLE_BUYER_PRIVATE_KEY
#   Private key of the agent's EOA wallet used to make gas-free nanopayments
#   server-side. NEVER prefix with NEXT_PUBLIC_.
#   Steps:
#     1. Create a new dedicated wallet (MetaMask → Add account → Create account)
#     2. Export private key (Account details → Show private key)
#     3. Fund it with Base Sepolia USDC at https://faucet.circle.com
CIRCLE_BUYER_PRIVATE_KEY=

# CIRCLE_SELLER_ADDRESS
#   EVM address that receives payments via the x402 /api/nanopay/sell endpoint.
#   Can be any wallet address you control.
CIRCLE_SELLER_ADDRESS=

# Optional overrides (leave blank to use defaults)
# CIRCLE_USDC_ADDRESS=       # Default: 0x036CbD53842c5426634e7929541eC2318f3dCF7e (Base Sepolia USDC)
# CIRCLE_GATEWAY_WALLET_ADDRESS=  # Default: fetched from Circle facilitator

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used by AI tools to call internal API routes (nanopay/*, etc.)
# Set to your Vercel deployment URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
