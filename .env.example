# Privy
NEXT_PUBLIC_PRIVY_APP_ID=

# Privy (server-side only — NEVER prefix with NEXT_PUBLIC_)
PRIVY_APP_SECRET=

# Alchemy RPC
NEXT_PUBLIC_ALCHEMY_API_KEY=

# YO Protocol (optional — partner attribution)
NEXT_PUBLIC_YO_PARTNER_ID=

# MoonPay (server-side only)
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=

# AI (server-side only)
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

# Circle Gateway Nanopayments — Base Sepolia
# EOA private key for the agent buyer wallet (server-side only, NEVER expose to client)
CIRCLE_BUYER_PRIVATE_KEY=
# EVM address that receives seller payments
CIRCLE_SELLER_ADDRESS=
# Optional: override USDC address on Base Sepolia (default: 0x036CbD53842c5426634e7929541eC2318f3dCF7e)
CIRCLE_USDC_ADDRESS=
# Optional: override GatewayWallet contract address (fetched from facilitator if omitted)
CIRCLE_GATEWAY_WALLET_ADDRESS=

# App base URL (used by AI tools to call internal API routes)
NEXT_PUBLIC_APP_URL=http://localhost:3000
